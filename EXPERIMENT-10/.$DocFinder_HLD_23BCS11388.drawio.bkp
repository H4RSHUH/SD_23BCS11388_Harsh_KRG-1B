        <mxCell id="api-b1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="1. &lt;b&gt;POST /api/upload&lt;/b&gt; — multipart/form-data; field: pdf; returns { jobId, collectionName }" vertex="1">
