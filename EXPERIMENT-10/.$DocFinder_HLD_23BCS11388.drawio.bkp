  <diagram name="DocFinder-HLD" id="DocFinderSystemDesign">
    <mxGraphModel dx="1429" dy="888" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1200" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title-1" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="&lt;b&gt;EXPERIMENT - DocFinder: AI-Powered PDF Question Answering System (RAG Architecture)&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="760" x="20" y="20" as="geometry" />
        </mxCell>
        <mxCell id="title-2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="DocFinder allows users to upload a PDF and ask questions strictly based on its content using vector embeddings and semantic search." vertex="1">
          <mxGeometry height="30" width="740" x="20" y="55" as="geometry" />
        </mxCell>
        <mxCell id="fr-0" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="&lt;b&gt;1. Functional Requirements&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="200" x="20" y="100" as="geometry" />
        </mxCell>
        <mxCell id="fr-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="A. User should be able to upload a PDF document (drag-and-drop or file picker)." vertex="1">
          <mxGeometry height="30" width="520" x="20" y="135" as="geometry" />
        </mxCell>
        <mxCell id="fr-2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="B. System should parse, chunk, and index the PDF in the background with progress tracking." vertex="1">
          <mxGeometry height="30" width="580" x="20" y="165" as="geometry" />
        </mxCell>
        <mxCell id="fr-3" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="C. User should be able to ask natural language questions about the uploaded PDF." vertex="1">
          <mxGeometry height="30" width="520" x="20" y="195" as="geometry" />
        </mxCell>
        <mxCell id="fr-4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="D. System must answer strictly from the PDF context — no hallucinated external knowledge." vertex="1">
          <mxGeometry height="30" width="540" x="20" y="225" as="geometry" />
        </mxCell>
        <mxCell id="fr-5" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="E. Answers should include page number references from the original PDF." vertex="1">
          <mxGeometry height="30" width="460" x="20" y="255" as="geometry" />
        </mxCell>
        <mxCell id="fr-6" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="F. UI should display session query history (sidebar on desktop, drawer on mobile) with scroll-to navigation." vertex="1">
          <mxGeometry height="30" width="620" x="20" y="285" as="geometry" />
        </mxCell>
        <mxCell id="fr-7" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="G. PDF file must be automatically deleted from disk after indexing is complete." vertex="1">
          <mxGeometry height="30" width="500" x="20" y="315" as="geometry" />
        </mxCell>
        <mxCell id="nfr-0" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="&lt;b&gt;2. Non-Functional Requirements&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="230" x="20" y="365" as="geometry" />
        </mxCell>
        <mxCell id="nfr-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="A. Availability: System should be highly available; indexing failures should not crash the server." vertex="1">
          <mxGeometry height="30" width="580" x="20" y="400" as="geometry" />
        </mxCell>
        <mxCell id="nfr-2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="B. Latency: Chat response time should be &lt; 5 seconds for typical PDFs (dependent on Gemini API)." vertex="1">
          <mxGeometry height="30" width="580" x="20" y="430" as="geometry" />
        </mxCell>
        <mxCell id="nfr-3" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="C. Rate Limiting: Global 100 req/15 min per IP; Chat 5 req/min; Upload 5 req/10 min — to protect AI cost." vertex="1">
          <mxGeometry height="30" width="620" x="20" y="460" as="geometry" />
        </mxCell>
        <mxCell id="nfr-4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="D. Security: PDF-only file filter enforced server-side; no sensitive data stored after indexing." vertex="1">
          <mxGeometry height="30" width="540" x="20" y="490" as="geometry" />
        </mxCell>
        <mxCell id="nfr-5" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="E. Responsiveness: UI must work on Desktop (sidebar layout) and Mobile (drawer layout) screens." vertex="1">
          <mxGeometry height="30" width="560" x="20" y="520" as="geometry" />
        </mxCell>
        <mxCell id="nfr-6" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="F. Consistency: In-memory job tracking acceptable for MVP; Redis recommended for production." vertex="1">
          <mxGeometry height="30" width="540" x="20" y="550" as="geometry" />
        </mxCell>
        <mxCell id="ce-0" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="&lt;b&gt;3. Core Entities&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="130" x="20" y="600" as="geometry" />
        </mxCell>
        <mxCell id="ce-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="A. PDF Document — uploaded file, parsed into chunks with page metadata" vertex="1">
          <mxGeometry height="30" width="440" x="20" y="635" as="geometry" />
        </mxCell>
        <mxCell id="ce-2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="B. Document Chunk — text segment with page number, stored as vector in Qdrant" vertex="1">
          <mxGeometry height="30" width="460" x="20" y="665" as="geometry" />
        </mxCell>
        <mxCell id="ce-3" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="C. Qdrant Collection — named pdf-{jobId}, one per upload session" vertex="1">
          <mxGeometry height="30" width="400" x="20" y="695" as="geometry" />
        </mxCell>
        <mxCell id="ce-4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="D. Indexing Job — in-memory job Map tracking: pending → processing → completed / failed" vertex="1">
          <mxGeometry height="30" width="500" x="20" y="725" as="geometry" />
        </mxCell>
        <mxCell id="ce-5" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="E. Chat Message — user query + AI response pair, stored client-side in React state" vertex="1">
          <mxGeometry height="30" width="480" x="20" y="755" as="geometry" />
        </mxCell>
        <mxCell id="ce-6" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="F. Embedding Vector — dense float array produced by gemini-embedding-001 model" vertex="1">
